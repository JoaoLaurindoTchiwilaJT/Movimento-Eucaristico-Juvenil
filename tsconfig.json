{
  "compilerOptions": {
    "target": "ES2023",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "./src",
    "outDir": "./dist",
    "baseUrl": "./src",
    "paths": {
      "@model/*": ["model/*"],
      "@controller/*": ["controller/*"],
      "@repository/*": ["repository/*"],
      "@router/*": ["router/*"]
    },
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "resolveJsonModule": true, // Permite importar arquivos JSON
    "allowJs": true, // Permite importar arquivos JavaScript
    "sourceMap": true, // Gera arquivos .map para depuração
    "declaration": true, // Gera arquivos .d.ts para melhor compatibilidade com bibliotecas
    "removeComments": true // Remove comentários no código compilado
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
