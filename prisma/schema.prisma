generator client {
  provider = "prisma-client"
  url      = env("DATABASE_URL") 
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  
}

model user {
  idMejista Int @id @default(autoincrement())

  nomeMembro   String
  email        String?
  senha        String?
  nivel        String
  role         Role
  cargo        String?
  numeroMembro String
  contacto     Int

  // relação com paroquia
  paroquiaId Int?
  paroquia   paroquias? @relation(fields: [paroquiaId], references: [idParoquia])

  // relação com centro
  centroId Int?
  centro   centrosParoquias? @relation(fields: [centroId], references: [idCentrosParoquias])

  livros   livros[]
  noticias noticias[]
}

enum Role {
  Admin
  User
}

model paroquias {
  idParoquia   Int    @id @default(autoincrement())
  nomeParoquia String
  qtdCentros   Int

  membros user[]

  centros centrosParoquias[]
}

model centrosParoquias {
  idCentrosParoquias Int @id @default(autoincrement())

  nomeCentro String
  qtdMembros Int
  coordenador coordenador?
  paroquiaId Int
  paroquia   paroquias @relation(fields: [paroquiaId], references: [idParoquia], onDelete: Cascade)

  membros user[]
}

enum coordenador {
  coordenadorParoquialCentroSede
  coordenadorCentral
}

model noticias {
  idNoticias Int @id @default(autoincrement())

  tituloNoticia String
  descricao     String
  dataPub       DateTime

  userId Int
  user   user @relation(fields: [userId], references: [idMejista], onDelete: Cascade)
}

model livros {
  idLivro Int @id @default(autoincrement())

  titulo       String
  url          String
  dataCadastro DateTime
  autor        String

  userId Int
  user   user @relation(fields: [userId], references: [idMejista], onDelete: Cascade)
}
